{
  "alias": "scanner.phar",
  "main": "script/scanner-tool.php",
  "output": "scanner.phar",
  "directories": [
    "src",
    "config",
    "script"
  ],
  "files": [
    "extension.neon"
  ],
  "finder": [
    {
      "name": "*.php",
      "in": "vendor",
      "exclude": [
        "tests",
        "test",
        "Tests",
        "Test",
        "docs",
        "doc"
      ]
    },
    {
      "name": "*.neon",
      "in": "vendor"
    },
    {
      "name": "autoload.php",
      "in": "vendor"
    }
  ],
  "compactors": [
    "KevinGH\\Box\\Compactor\\Php"
  ],
  "compression": "GZ"
}
