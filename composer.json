{
    "name": "imsuperlative/phpstan-filament",
    "description": "PHPStan extension that types $this in Filament PHP",
    "type": "phpstan-extension",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "phpstan/phpstan": "^2.1"
    },
    "suggest": {
        "larastan/larastan": "Enriches model property type resolution from migrations and casts"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "filament/filament": "^5.0",
        "larastan/larastan": "^3.4",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "ImSuperlative\\PhpstanFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "ImSuperlative\\PhpstanFilament\\Tests\\": "tests/",
            "Fixtures\\App\\": "tests/Fixtures/App/"
        },
        "exclude-from-classmap": [
            "tests/Fixtures/App/Models/_ide_helper_models.php",
            "tests/Fixtures/App/ClosureTests/",
            "tests/Fixtures/SmokeTest.php",
            "tests/Fixtures/SchemaCallSite.php",
            "tests/Fixtures/OperationLiteralAssertions.php"
        ]
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan --configuration=phpstan.neon",
        "phpstan:clear": "vendor/bin/phpstan clear-result-cache",
        "phpstan:fresh": "vendor/bin/phpstan clear-result-cache && vendor/bin/phpstan --configuration=phpstan.neon"
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
