{
    "name": "imsuperlative/filament-phpstan",
    "description": "PHPStan extension that types $this in Filament PHP",
    "type": "phpstan-extension",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "phpstan/phpstan": "^2.1"
    },
    "suggest": {
        "larastan/larastan": "Enriches model property type resolution from migrations and casts"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "filament/filament": "^5.0",
        "larastan/larastan": "^3.4",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "files": [
            "src/Support/helpers.php"
        ],
        "psr-4": {
            "ImSuperlative\\FilamentPhpstan\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ImSuperlative\\FilamentPhpstan\\Tests\\": "tests/",
            "Fixtures\\App\\": "tests/Fixtures/App/"
        }
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan --configuration=phpstan.neon.dist",
        "phpstan:clear": "vendor/bin/phpstan clear-result-cache"
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
