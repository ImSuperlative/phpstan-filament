# Feature: IDE Helper model property/method integration
# Enabled by: PhpstanFilament.typeIdeHelper (default: true)
# Custom path: PhpstanFilament.ideHelperPath (default: '', auto-detect)

services:
    -
        class: ImSuperlative\PhpstanFilament\Extensions\IdeHelper\IdeHelperPropertiesExtension
        tags:
            - phpstan.broker.propertiesClassReflectionExtension

    -
        class: ImSuperlative\PhpstanFilament\Extensions\IdeHelper\IdeHelperMethodsExtension
        tags:
            - phpstan.broker.methodsClassReflectionExtension
