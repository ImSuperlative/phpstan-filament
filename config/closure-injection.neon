# Feature #9: Closure injection validation
# Enabled by: filamentPhpstan.checkClosureInjection (default: true)

services:
    -
        class: ImSuperlative\FilamentPhpstan\Rules\ClosureInjection\ClosureInjectionRule
        tags:
            - phpstan.rules.rule
        arguments:
            closureInjection: %filamentPhpstan.checkClosureInjection%
            reservedClosureInjection: %filamentPhpstan.checkReservedClosureInjection%
