# Feature: make('field') validation (levels 0/1/2)
# Enabled by: filamentPhpstan.checkFieldPaths (default: 1)

services:
    -
        class: ImSuperlative\FilamentPhpstan\Collectors\VirtualFieldRegistry

    -
        class: ImSuperlative\FilamentPhpstan\Collectors\StateOverrideCollector
        tags:
            - phpstan.collector

    -
        class: ImSuperlative\FilamentPhpstan\Collectors\AggregateFieldRegistry

    -
        class: ImSuperlative\FilamentPhpstan\Collectors\AggregateOverrideCollector
        tags:
            - phpstan.collector

    -
        class: ImSuperlative\FilamentPhpstan\Collectors\RecordsTableCollector
        tags:
            - phpstan.collector

    -
        class: ImSuperlative\FilamentPhpstan\Collectors\CustomComponentRegistry

    -
        class: ImSuperlative\FilamentPhpstan\Collectors\CustomComponentCollector
        tags:
            - phpstan.collector

    -
        class: ImSuperlative\FilamentPhpstan\FieldValidationLevel
        factory: ImSuperlative\FilamentPhpstan\FieldValidationLevel::from(%filamentPhpstan.checkFieldPaths%)

    -
        class: ImSuperlative\FilamentPhpstan\Rules\MakeFieldValidation\AggregateFieldValidator

    -
        class: ImSuperlative\FilamentPhpstan\Rules\MakeFieldValidation\MakeFieldValidationRule
        tags:
            - phpstan.rules.rule